/* Base Themes and Reset */
:root {
    --bg-color: #ffffff;
    --text-color: #333333;
    --nav-bg: transparent;
    --nav-scrolled: #f8f9fa;
    --card-bg: #f0f0f0;
    --accent-color: #007bff;
    --error-color: #dc3545;
}

body.dark-mode {
    --bg-color: #121212;
    --text-color: #ffffff;
    --nav-bg: transparent;
    --nav-scrolled: #222222;
    --card-bg: #1e1e1e;
    --accent-color: #bb86fc;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

body {
    background-color: var(--bg-color);
    color: var(--text-color);
    transition: background 0.3s, color 0.3s;
}

/* Dynamic Navbar Style */
nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
    background-color: var(--nav-bg);
    transition: background 0.3s, box-shadow 0.3s;
    padding: 20px 0;
}

nav.scrolled {
    background-color: var(--nav-scrolled);
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    padding: 15px 0;
}

.nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
}

.logo {
    font-size: 24px;
    font-weight: bold;
    text-decoration: none;
    color: var(--text-color);
}

.nav-links {
    display: flex;
    list-style: none;
    gap: 20px;
}

.nav-links a {
    text-decoration: none;
    color: var(--text-color);
    font-weight: 500;
}

.nav-links a.active {
    color: var(--accent-color);
    border-bottom: 2px solid var(--accent-color);
}

/* Toggle Button */
.btn-toggle {
    padding: 8px 12px;
    cursor: pointer;
    background-color: var(--accent-color);
    color: #fff;
    border: none;
    border-radius: 4px;
}

/* Sections Layout */
.section {
    padding: 100px 20px 60px 20px;
    min-height: 80vh;
}

.container {
    max-width: 800px;
    margin: 0 auto;
}

h1, h2 {
    margin-bottom: 20px;
}

.education {
    margin: 10px 0;
    font-size: 18px;
}

.project-card {
    background-color: var(--card-bg);
    padding: 20px;
    border-radius: 8px;
    margin-top: 20px;
}

/* Form Styles */
.contact-info {
    margin-bottom: 20px;
}

.contact-info p {
    margin-bottom: 5px;
}

.contact-info a {
    color: var(--accent-color);
}

.form-group {
    margin-bottom: 15px;
}

label {
    display: block;
    margin-bottom: 5px;
}

input, textarea {
    width: 100%;
    padding: 10px;
    border: 1px solid #ccc;
    border-radius: 4px;
    background: transparent;
    color: var(--text-color);
}

.btn-submit {
    padding: 10px 20px;
    background-color: var(--accent-color);
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
}

/* Inline Error Messaging */
.error-msg {
    color: var(--error-color);
    font-size: 13px;
    display: block;
    margin-top: 5px;
    height: 15px;
}

